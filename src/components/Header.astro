---
import "../styles/global.css";
---

<!-- ═══════════════ NAVBAR ═══════════════ -->
<nav
  id="navbar"
  class="fixed z-50 w-full border-b border-white/5 bg-[#0a0a0a]/80 backdrop-blur-md transition-all duration-300"
>
  <div class="container mx-auto flex items-center justify-between px-6 py-4">
    <!-- Logo -->
    <a
      href="#"
      class="text-2xl tracking-widest text-white md:text-3xl"
      style="font-family: 'Playfair Display', serif;"
    >
      NOIR <span class="text-[#d4af37]">ATELIER</span>
    </a>

    <!-- Links desktop -->
    <div
      class="hidden space-x-8 text-sm font-light tracking-widest uppercase md:flex"
      style="font-family: 'Montserrat', sans-serif;"
    >
      <a href="#hero" class="nav-link text-gray-300 transition hover:text-[#d4af37]">Inicio</a>
      <a href="#servicios" class="nav-link text-gray-300 transition hover:text-[#d4af37]"
        >Servicios</a
      >
      <a href="#nosotros" class="nav-link text-gray-300 transition hover:text-[#d4af37]"
        >Sobre Nosotros</a
      >
      <a href="#galeria" class="nav-link text-gray-300 transition hover:text-[#d4af37]">Galería</a>
      <a href="#testimonios" class="nav-link text-gray-300 transition hover:text-[#d4af37]"
        >Opiniones</a
      >
    </div>

    <!-- CTA reservar -->
    <a
      href="#contacto"
      class="hidden border border-[#d4af37] px-6 py-2 text-xs font-semibold tracking-widest text-[#d4af37] uppercase transition-colors duration-300 hover:bg-[#d4af37] hover:text-[#0a0a0a] md:inline-block"
    >
      Reservar
    </a>

    <!-- Hamburguesa móvil -->
    <button
      id="menu-btn"
      class="text-[#d4af37] focus:outline-none md:hidden"
      aria-label="Abrir menú"
    >
      <i class="fas fa-bars text-2xl"></i>
    </button>
  </div>

  <!-- Menú móvil -->
  <div
    id="mobile-menu"
    class="absolute hidden w-full border-b border-[#d4af37]/20 bg-[#121212] md:hidden"
  >
    <div class="flex flex-col items-center space-y-4 py-6 text-sm tracking-widest uppercase">
      <a href="#hero" class="text-gray-300 hover:text-[#d4af37]">Inicio</a>
      <a href="#servicios" class="text-gray-300 hover:text-[#d4af37]">Servicios</a>
      <a href="#nosotros" class="text-gray-300 hover:text-[#d4af37]">Sobre Nosotros</a>
      <a href="#galeria" class="text-gray-300 hover:text-[#d4af37]">Galería</a>
      <a href="#contacto" class="border-b border-[#d4af37] pb-1 font-bold text-[#d4af37]"
        >Reservar Mesa</a
      >
    </div>
  </div>
</nav>

<!-- ═══════════════ HERO ═══════════════ -->
<section id="hero" class="relative flex h-screen items-center justify-center overflow-hidden">
  <!-- Imagen de fondo + overlay -->
  <div class="absolute inset-0 z-0">
    <img
      src="https://images.unsplash.com/photo-1514362545857-3bc16c4c7d1b?ixlib=rb-1.2.1&auto=format&fit=crop&w=1950&q=80"
      alt="Restaurante Dark Mood"
      class="h-full w-full object-cover"
    />
    <div class="absolute inset-0 bg-linear-to-b from-black/80 via-black/50 to-[#121212]"></div>
  </div>

  <!-- Contenido -->
  <div class="reveal active relative z-10 mx-auto max-w-5xl px-6 text-center">
    <p class="mb-4 text-sm tracking-[0.3em] text-[#d4af37] uppercase md:text-base">
      Experiencia Gourmet &amp; Sensorial
    </p>
    <h1
      class="mb-6 text-4xl leading-tight text-white md:text-6xl lg:text-7xl"
      style="font-family: 'Playfair Display', serif;"
    >
      Sabores que desafían<br />
      <span class="text-gray-300 italic">los sentidos más exigentes</span>
    </h1>
    <p class="mx-auto mb-10 max-w-3xl text-lg font-light text-gray-300 md:text-xl">
      Donde la alta cocina se encuentra con la arquitectura del deseo. Una experiencia culinaria
      exclusiva en el corazón de la ciudad.
    </p>

    <div class="flex flex-col justify-center gap-4 md:flex-row">
      <a
        href="#contacto"
        class="bg-[#d4af37] px-8 py-4 text-sm font-bold tracking-widest text-[#0a0a0a] uppercase transition-colors duration-300 hover:bg-white"
      >
        Agendar Cita
      </a>
      <a
        href="#galeria"
        class="border border-white px-8 py-4 text-sm font-bold tracking-widest text-white uppercase transition-colors duration-300 hover:bg-white hover:text-[#0a0a0a]"
      >
        Ver Galería
      </a>
    </div>
  </div>

  <!-- Flecha animada -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce text-white/50">
    <i class="fas fa-chevron-down"></i>
  </div>
</section>

<!-- ═══════════════ JS del Header ═══════════════ -->
<script>
  // ── Toggle menú móvil ────────────────────────────
  const menuBtn = document.getElementById("menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");

  menuBtn?.addEventListener("click", () => {
    mobileMenu?.classList.toggle("hidden");
  });

  // Cerrar al tocar un enlace
  mobileMenu?.querySelectorAll("a").forEach((link) => {
    link.addEventListener("click", () => mobileMenu.classList.add("hidden"));
  });

  // ── Navbar sticky: sólido al bajar ──────────────
  const navbar = document.getElementById("navbar");
  window.addEventListener("scroll", () => {
    if (!navbar) return;
    if (window.scrollY > 50) {
      navbar.classList.add("shadow-lg", "bg-[#0a0a0a]");
      navbar.classList.remove("bg-[#0a0a0a]/80");
    } else {
      navbar.classList.remove("shadow-lg", "bg-[#0a0a0a]");
      navbar.classList.add("bg-[#0a0a0a]/80");
    }
  });

  // ── Intersection Observer para animaciones .reveal ─
  const revealEls = document.querySelectorAll<HTMLElement>(".reveal");

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("active");
          observer.unobserve(entry.target); // solo una vez
        }
      });
    },
    { threshold: 0.12 }
  );

  revealEls.forEach((el) => observer.observe(el));
</script>
